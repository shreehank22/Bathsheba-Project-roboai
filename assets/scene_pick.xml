<mujoco model="panda_pick_place">

    <include file="scene.xml"/>

    <worldbody>

        <!-- Table — in front of arm, reachable height -->
        <body name="table" pos="0.5 0 0.2">
            <geom type="box" size="0.3 0.3 0.2" rgba="0.8 0.6 0.4 1"/>
        </body>

        <!-- Red cube sitting on table surface (z = 0.2*2 + 0.025 = 0.425) -->
        <body name="cube" pos="0.5 0 0.425">
            <joint type="free"/>
            <geom type="box" size="0.025 0.025 0.025" rgba="1 0 0 1"/>
        </body>

        <!-- Fixed camera looking at workspace -->
        <camera name="fixed_cam"
                pos="0.5 -0.8 1.2"
                xyaxes="1 0 0 0 0.6 0.8"
                fovy="60"/>

    </worldbody>

</mujoco>